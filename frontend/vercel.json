{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm ci --legacy-peer-deps",
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "env": {
    "GENERATE_SOURCEMAP": "false"
  },
  "rewrites": [
    { "source": "/((?!static/).*)", "destination": "/index.html" }
  ]
}
